{
  "name": "chickenwing",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dev": "vite",
    "build": "vite build && electron-builder"
  },
  "dependencies": {
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1",
    "wait-on": "^9.0.5"
  },
  "author": "muhammedaman",
  "description": "Premium Network Traffic Analyzer",
  "build": {
    "appId": "com.muhammedaman.chickenwing",
    "productName": "Chickenwing",
    "artifactName": "chickenwing.${ext}",
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "backend/**/*",
      "!backend/.api_token",
      "main.js",
      "package.json",
      "icon.png"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chickenwing",
      "include": "installer.nsh"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png",
      "requestedExecutionLevel": "requireAdministrator"
    }
  }
}
